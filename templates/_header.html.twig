{# Navbar présente sur toutes les pages sauf login #}
{% if app.user %}
    <nav class="navbar navbar-expand-lg">
        <div class="container">

            {# Logo à gauche #}
            <a class="navbar-brand" href="{{ path('app_home') }}">LOGO Sortir.com</a>

            {# Bouton hamburger pour mobile (responsive) #}
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            {# Liens de navigation à droite #}
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">

                    {# Lien Administration uniquement pour les admins #}
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_admin') }}">Administration</a>
                        </li>
                    {% endif %}

                    {# Accueil #}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                    </li>

                    {# Mon profil #}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_profil') }}">Mon profil</a>
                    </li>

                    {# Se déconnecter #}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_logout') }}">Se déconnecter</a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>
{% endif %}
