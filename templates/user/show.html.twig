{% extends 'base.html.twig' %}

{% block title %}Profil de {{ user.username }}{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="row">

            {# Colonne gauche - Photo #}
            <div class="col-md-2 text-center">
                <img src="{{ asset('images/avatar-placeholder.png') }}"
                     alt="Photo de profil"
                     class="img-thumbnail"
                     style="max-width: 130px;">
            </div>

            {# Colonne centre - Infos style formulaire #}
            <div class="col-md-7">

                <h2 class="text-center mb-4">{{ user.username }}</h2>

                {# Campus #}
                <div class="row mb-3 align-items-center">
                    <div class="col-sm-4 fw-bold">Campus</div>
                    <div class="col-sm-8">
                        <span class="form-control-plaintext">{{ user.campus }}</span>
                    </div>
                </div>

                {# Prénom #}
                <div class="row mb-3 align-items-center">
                    <div class="col-sm-4 fw-bold">Prénom</div>
                    <div class="col-sm-8">
                        <span class="form-control-plaintext">{{ user.firstName }}</span>
                    </div>
                </div>

                {# Nom #}
                <div class="row mb-3 align-items-center">
                    <div class="col-sm-4 fw-bold">Nom</div>
                    <div class="col-sm-8">
                        <span class="form-control-plaintext">{{ user.lastName }}</span>
                    </div>
                </div>

                {# Téléphone #}
                <div class="row mb-3 align-items-center">
                    <div class="col-sm-4 fw-bold">Téléphone</div>
                    <div class="col-sm-8">
                        <span class="form-control-plaintext">{{ user.phoneNumber }}</span>
                    </div>
                </div>

                {# Email #}
                <div class="row mb-3 align-items-center">
                    <div class="col-sm-4 fw-bold">Email</div>
                    <div class="col-sm-8">
                        <span class="form-control-plaintext">{{ user.email }}</span>
                    </div>
                </div>

                {# Bouton Modifier uniquement si c'est mon propre profil #}
                {% if app.user == user %}
                    <div class="text-center mt-4">
                        <a href="{{ path('app_profil') }}" class="btn btn-primary px-4">Modifier</a>
                    </div>
                {% endif %}

            </div>

        </div>
    </div>
{% endblock %}
