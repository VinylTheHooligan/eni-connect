{% extends 'base.html.twig' %}

{% block title %}Gérer les campus{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="h4 text-center mb-4">Gérer les campus</h1>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('danger') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        <div class="row align-items-start g-3 mb-3">
            <div class="col-lg-6">
                <form method="get" action="{{ path('app_admin_campuses') }}">
                    <fieldset class="border rounded p-3">
                        <legend class="float-none w-auto px-2 fs-6 mb-0">Filtrer les campus</legend>
                        <label for="q" class="form-label mt-2 mb-1">Le nom contient</label>
                        <div class="d-flex gap-2">
                            <input id="q" type="text" name="q"
                                   value="{{ app.request.get('q') }}"
                                   class="form-control" style="max-width: 260px;"
                                   placeholder="search">
                            <button type="submit" class="btn btn-outline-dark">Rechercher</button>
                        </div>
                    </fieldset>
                </form>
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h2 class="h6 mb-0">Liste des campus</h2>
            <a href="{{ path('app_admin_campus_add') }}" class="btn btn-sm btn-outline-dark">
                Ajouter un campus
            </a>
        </div>
        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
            <table class="table table-sm table-striped table-bordered w-100">
                <thead class="table-light">
                <tr>
                    <th style="width: 80%;">
                        <a href="?q={{ app.request.get('q') }}&sort=name&order={{ app.request.get('sort') == 'name' and app.request.get('order') == 'asc' ? 'desc' : 'asc' }}" class="text-dark text-decoration-none">
                            Campus
                            {% if app.request.get('sort') == 'name' %}
                                {{ app.request.get('order') == 'asc' ? '▲' : '▼' }}
                            {% else %}
                                ↕
                            {% endif %}
                        </a>
                    </th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for campus in campuses %}
                    <tr>
                        <td>{{ campus.name }}</td>
                        <td>
                            <a href="{{ path('app_admin_campus_edit', {'id': campus.id}) }}" class="btn btn-sm btn-outline-dark">Modifier</a>
                            <span class="mx-1"></span>
                            <form method="post" action="{{ path('app_admin_campus_delete', {'id': campus.id}) }}"
                                  class="d-inline"
                                  onsubmit="return confirm('Confirmer la suppression du campus ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_campus_' ~ campus.id) }}">
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    Supprimer
                                </button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="2" class="text-center">Aucun campus trouvé.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <a href="{{ path('app_admin') }}" class="btn btn-outline-secondary">Retour</a>
        </div>
    </div>
{% endblock %}
