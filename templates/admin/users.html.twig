{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="h4 text-center mb-4">Gérer les utilisateurs</h1>

        {# Flash messages #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('warning') %}
            <div class="alert alert-warning">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('danger') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        <div class="row align-items-start g-3 mb-3">
            {# Filtre #}
            <div class="col-lg-6">
                <form method="get" action="{{ path('app_admin_users') }}">
                    <fieldset class="border rounded p-3">
                        <legend class="float-none w-auto px-2 fs-6 mb-0">Filtrer les utilisateurs</legend>
                        <label for="q" class="form-label mt-2 mb-1">Le nom contient</label>
                        <div class="d-flex gap-2">
                            <input id="q" type="text" name="q" value="{{ app.request.get('q') }}"
                                   class="form-control" placeholder="search">
                            <button type="submit" class="btn btn-outline-dark">Rechercher</button>
                        </div>
                    </fieldset>
                </form>
            </div>

        {# Colonne droite laissée vide pour l’instant (alignement maquette) #}
        <div class="col-lg-6"></div>
    </div>

    <form method="post" action="{{ path('app_admin_user_bulk') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('user_bulk_action') }}">

        <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="d-flex align-items-center gap-3">
                <h2 class="h6 mb-0">Liste des utilisateurs</h2>
                <div class="d-flex gap-2 align-items-center">
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" id="select_all_users_top">
                        <label class="form-check-label small" for="select_all_users_top">
                            Tout sélectionner / désélectionner
                        </label>
                   </div>
                   <button type="submit" name="bulk_deactivate" class="btn btn-sm btn-outline-warning"
                           onclick="return confirm('Mettre les utilisateurs sélectionnés en inactif ?');">
                       Tout désactiver (sélection)
                   </button>
                   <button type="submit" name="bulk_delete" class="btn btn-sm btn-outline-danger"
                           onclick="return confirm('Supprimer définitivement les utilisateurs sélectionnés ?');">
                       Supprimer la sélection
                   </button>
                </div>
            </div>

            <div class="d-flex gap-2">
                <a href="{{ path('app_admin_user_import') }}" class="btn btn-sm btn-outline-secondary">
                    Importer un fichier CSV
                </a>
                <a href="{{ path('app_admin_user_add') }}" class="btn btn-sm btn-outline-dark">
                    Ajouter un utilisateur
                </a>
            </div>
        </div>
            <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                <table class="table table-sm table-striped table-bordered w-100">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 1%;"></th>
                            <th>
                                <a href="?q={{ app.request.get('q') }}&sort=username&order={{ app.request.get('sort') == 'username' and app.request.get('order') == 'asc' ? 'desc' : 'asc' }}" class="text-dark text-decoration-none">
                                    Pseudo
                                    {% if app.request.get('sort') == 'username' %}
                                        {{ app.request.get('order') == 'asc' ? '▲' : '▼' }}
                                    {% else %}
                                        ↕
                                    {% endif %}
                                </a>
                            </th>
                            <th>
                                <a href="?q={{ app.request.get('q') }}&sort=lastName&order={{ app.request.get('sort') == 'lastName' and app.request.get('order') == 'asc' ? 'desc' : 'asc' }}" class="text-dark text-decoration-none">
                                    Nom
                                    {% if app.request.get('sort') == 'lastName' %}
                                        {{ app.request.get('order') == 'asc' ? '▲' : '▼' }}
                                    {% else %}
                                        ↕
                                    {% endif %}
                                </a>
                            </th>
                            <th>
                                <a href="?q={{ app.request.get('q') }}&sort=firstName&order={{ app.request.get('sort') == 'firstName' and app.request.get('order') == 'asc' ? 'desc' : 'asc' }}" class="text-dark text-decoration-none">
                                    Prénom
                                    {% if app.request.get('sort') == 'firstName' %}
                                        {{ app.request.get('order') == 'asc' ? '▲' : '▼' }}
                                    {% else %}
                                        ↕
                                    {% endif %}
                                </a>
                            </th>
                            <th>Email</th>
                            <th>Campus</th>
                            <th>Rôles</th>
                            <th>Actif</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for user in users %}
                        <tr>
                            <td>
                                <input type="checkbox" name="user_ids[]" value="{{ user.id }}"
                                class="user-select-checkbox" aria-label="Sélectionner l'utilisateur {{ user.username }}">
                            </td>
                            <td data-label="Pseudo">{{ user.username }}</td>
                            <td data-label="Nom">{{ user.lastName }}</td>
                            <td data-label="Prénom">{{ user.firstName }}</td>
                            <td data-label="Email">{{ user.email }}</td>
                            <td data-label="Campus">{{ user.campus ? user.campus.name : '-' }}</td>
                            <td data-label="Rôles">{{ user.roles|join(', ') }}</td>
                            <td data-label="Actif">{{ user.isactive ? 'Oui' : 'Non' }}</td>
                            <td data-label="Actions">
                                <a href="{{ path('app_admin_user_toggle', {'id': user.id}) }}" class="btn btn-sm btn-outline-dark">
                                    {{ user.isactive ? 'Désactiver' : 'Activer' }}
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </form>
        <a href="{{ path('app_admin') }}" class="btn btn-outline-secondary mt-3">Retour</a>
    </div>

    {# Sélection / dé-sélection globale des utilisateurs #}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const selectAll = document.getElementById('select_all_users_top');
            const checkboxes = document.querySelectorAll('.user-select-checkbox');

            if (selectAll) {
                selectAll.addEventListener('change', function () {
                    checkboxes.forEach(cb => cb.checked = selectAll.checked);
                });
            }
        });
    </script>
{% endblock %}
