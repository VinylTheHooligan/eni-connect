{% extends 'base.html.twig' %}

{% block title %}Administration - Sortir.com{% endblock %}

{% block body %}
<div class="container mt-5">

    <h1 class="h4 text-center mb-4">Page d'administration</h1>

    <p class="text-center mb-4">
        Bienvenue {{ app.user.username ?? app.user.email }}.
    </p>

    <div class="d-flex justify-content-center mb-4">
        <div class="btn-group" role="group" aria-label="Navigation administration">
            {# Gérer les campus – à brancher sur la future page de gestion des campus #}
            <a href="{{ path('app_admin_campuses') }}"
               class="btn btn-outline-dark">
                Gérer les campus
            </a>

            <a href="{{ path('app_admin_cities') }}"
               class="btn btn-outline-dark">
                Gérer les villes
            </a>

            <a href="{{ path('app_admin_users') }}"
               class="btn btn-outline-dark">
                Gérer les utilisateurs
            </a>
        </div>
    </div>

</div>
{% endblock %}
