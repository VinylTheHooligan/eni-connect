{% extends 'base.html.twig' %}

{% block title %}Administration - Sortir.com{% endblock %}

{% block body %}
    <div class="container mt-5">

        <h1 class="text-center mb-2">Administration</h1>
        <p class="text-center mb-5" style="color: var(--muted-color);">
            Bienvenue {{ app.user.username ?? app.user.email }}.
        </p>

        <div class="row justify-content-center g-4">
            <div class="col-md-3">
                <a href="{{ path('app_admin_campuses') }}" class="text-decoration-none card-link">
                    <div class="card admin-card">
                        <h5 class="mb-1">Campus</h5>
                        <p style="color: var(--muted-color); font-size: 13px; margin: 0;">Gérer les campus</p>
                    </div>
                </a>
            </div>
            <div class="col-md-3">

                <a href="{{ path('app_admin_cities') }}" class="text-decoration-none card-link">
                    <div class="card admin-card">
                        <h5 class="mb-1">Villes</h5>
                        <p style="color: var(--muted-color); font-size: 13px; margin: 0;">Gérer les villes</p>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a href="{{ path('app_admin_users') }}" class="text-decoration-none card-link">
                    <div class="card admin-card">
                        <h5 class="mb-1">Utilisateurs</h5>
                        <p style="color: var(--muted-color); font-size: 13px; margin: 0;">Gérer les utilisateurs</p>
                    </div>
                </a>
            </div>
        </div>

    </div>
{% endblock %}
