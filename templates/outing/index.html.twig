{% extends 'base.html.twig' %}

{% block title %}Sortir - Accueil | {{ parent() }}{% endblock %}

{% block body %}
<div class="container mt-4">
    {# Bandeau haut : titre + infos à droite #}
    <div class="row align-items-center mb-3">
        <div class="col-md-6">
            <h1 class="h4 mb-0">Sortir - Accueil</h1>
        </div>
        <div class="col-md-6 text-md-end mt-2 mt-md-0">
            <div class="small">
                <div>Date du jour : {{ "now"|date('d/m/Y') }}</div>
                {% if app.user %}
                    <div>Participant : {{ app.user.username ?? app.user.email }}</div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="row">
        {# Filtres #}
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-body">
                    <h2 class="h6 mb-3">Filtrer les sorties</h2>

                    <form method="get" class="row g-2">
                        {# Campus #}
                        <div class="col-12">
                            <label for="campus" class="form-label mb-1">Campus</label>
                            <select id="campus" name="campus" class="form-select form-select-sm w-auto">
                                <option value="">Tous</option>
                                {% for campus in campuses %}
                                    <option value="{{ campus.id }}"
                                            {% if filters.campus is defined and filters.campus == campus.id %}
                                            selected{% endif %}>
                                        {{ campus.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        {# Nom contient la touche suivante#}
                        <div class="col-12">
                            <label for="q" class="form-label mb-1">Le nom de la sortie contient le terme suivant :</label>
                            <div class="input-group input-group-sm" style="max-width: 260px;">
                                <input type="text"
                                       id="q"
                                       name="q"
                                       value="{{ app.request.get('q') }}"
                                       class="form-control"
                                       placeholder="search">
                            </div>
                        </div>

                        {# Entre deux dates #}
                        <div class="col-12">
                            <label class="form-label mb-1 d-block">Entre</label>
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <input type="date"
                                       id="dateFrom"
                                       name="dateFrom"
                                       value="{{ app.request.get('dateFrom') }}"
                                       class="form-control form-control-sm"
                                       style="max-width: 160px;"
                                       aria-label="Date de début">
                                <span class="small">et</span>
                                <input type="date"
                                       id="dateTo"
                                       name="dateTo"
                                       value="{{ app.request.get('dateTo') }}"
                                       class="form-control form-control-sm"
                                       style="max-width: 160px;"
                                       aria-label="Date de fin">
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        {# Cases à cocher + bouton Rechercher à droite #}
        <div class="col-lg-4">
            <div class="card mb-3">
                <div class="card-body">
                    <form method="get" class="d-flex flex-column gap-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="isOrganizer" id="isOrganizer"
                                   {% if app.request.get('isOrganizer') %}checked{% endif %}>
                            <label class="form-check-label" for="isOrganizer">
                                Sorties dont je suis l'organisateur/trice
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="isRegistered" id="isRegistered"
                                   {% if app.request.get('isRegistered') %}checked{% endif %}>
                            <label class="form-check-label" for="isRegistered">
                                Sorties auxquelles je suis inscrit/e
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="isNotRegistered" id="isNotRegistered"
                                   {% if app.request.get('isNotRegistered') %}checked{% endif %}>
                            <label class="form-check-label" for="isNotRegistered">
                                Sorties auxquelles je ne suis pas inscrit/e
                            </label>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" name="isPast" id="isPast"
                                   {% if app.request.get('isPast') %}checked{% endif %}>
                            <label class="form-check-label" for="isPast">
                                Sorties terminées
                            </label>
                        </div>
                        <div class="text-end">
                            <button type="submit" class="btn btn-outline-dark">
                                Rechercher
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        {# Tableau des sorties #}
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-sm table-striped table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Nom de la sortie</th>
                            <th scope="col">Date de la sortie</th>
                            <th scope="col">Clôture</th>
                            <th scope="col">Inscrits/Places</th>
                            <th scope="col">État</th>
                            <th scope="col">Inscrit</th>
                            <th scope="col">Organisateur</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for outing in outings %}
                        <tr>
                            <td>{{ outing.name }}</td>
                            <td>{{ outing.startDateTime|date('d/m/Y H:i') }}</td>
                            <td>{{ outing.registrationDeadline|date('d/m/Y') }}</td>
                            <td>{{ outing.registrations|length }}/{{ outing.maxRegistrations }}</td>
                            <td>{{ outing.status }}</td>
                            <td>
                                {# Filtre si l'utilisateur courant est inscrit #}
                                {% if app.user and outing.registrations|filter(r => r.participant == app.user)|length > 0 %}
                                    X
                                {% endif %}
                            </td>
                            <td>{{ outing.organizer.username ?? outing.organizer.email }}</td>
                            <td>
                                {# todos: placeholders d’actions, à brancher sur les routes plus tard #}
                                <a href="#" class="link-primary">Afficher</a>
                                {# todos : autres actions selon le statut : S'inscrire, Se désister, Annuler, etc #}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" class="text-center">Aucune sortie trouvée.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                <a href="{{ path('outing_create') }}" class="btn btn-outline-dark">
                    Créer une sortie
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
