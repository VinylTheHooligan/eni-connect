{% extends 'base.html.twig' %}

{% block title %}Sortir - Accueil | {{ parent() }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row align-items-center mb-3">
        <div class="col-md-6">
            <h1 class="h4 mb-0">Accueil</h1>
        </div>
        <div class="col-md-6 text-md-end mt-2 mt-md-0">
            <div class="small">
                <div>Date du jour : {{ "now"|date('d/m/Y') }}</div>
                {% if app.user %}
                    <div>Participant : {{ app.user.username ?? app.user.email }}</div>
                {% endif %}
            </div>
        </div>
    </div>

    {% for label, messages in app.flashes %}
        {% set message = messages|last %}
        <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="row">
        <div class="col-12">
            <div class="card mb-3">
                <div class="card-body">
                    <h2 class="h6 mb-3">Filtrer les sorties</h2>

                    <form method="get" action="{{ path('outing_list') }}">
                        <div class="row">
                            <fieldset class="col-lg-8 border-0">
                                <legend class="visually-hidden">Critères de recherche</legend>

                                <div class="row g-2">
                                    <div class="col-12">
                                        <label for="campus" class="form-label mb-1">Campus</label>
                                        <select id="campus" name="campus" class="form-select form-select-sm w-auto">
                                            <option value="">Tous</option>
                                            {% for campus in campuses %}
                                                <option value="{{ campus.id }}"
                                                    {% if filters.campus is defined and filters.campus == campus.id %}selected{% endif %}>
                                                    {{ campus.name }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>

                                    <div class="col-12">
                                        <label for="q" class="form-label mb-1">Le nom de la sortie contient le terme suivant :</label>
                                        <input type="text"
                                               id="q"
                                               name="q"
                                               value="{{ filters.q ?? '' }}"
                                               class="form-control form-control-sm"
                                               style="max-width: 260px;"
                                               placeholder="search"
                                               aria-label="Recherche par nom">
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label mb-1 d-block">Entre</label>
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <input type="date"
                                                   id="dateFrom"
                                                   name="dateFrom"
                                                   value="{{ filters.dateFrom ?? '' }}"
                                                   class="form-control form-control-sm"
                                                   style="max-width: 160px;"
                                                   aria-label="Date de début">
                                            <span class="small">et</span>
                                            <input type="date"
                                                   id="dateTo"
                                                   name="dateTo"
                                                   value="{{ filters.dateTo ?? '' }}"
                                                   class="form-control form-control-sm"
                                                   style="max-width: 160px;"
                                                   aria-label="Date de fin">
                                        </div>
                                    </div>
                                </div>
                            </fieldset>
                            <fieldset class="col-lg-4 border-0">
                                <legend class="visually-hidden">Options de filtre</legend>
                                <div class="d-flex flex-column gap-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="isOrganizer" id="isOrganizer" value="1"
                                            {% if filters.isOrganizer %}checked{% endif %}>
                                        <label class="form-check-label" for="isOrganizer">
                                            Sorties dont je suis l'organisateur/trice
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="isRegistered" id="isRegistered" value="1"
                                            {% if filters.isRegistered %}checked{% endif %}>
                                        <label class="form-check-label" for="isRegistered">
                                            Sorties auxquelles je suis inscrit/e
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="isNotRegistered" id="isNotRegistered" value="1"
                                            {% if filters.isNotRegistered %}checked{% endif %}>
                                        <label class="form-check-label" for="isNotRegistered">
                                            Sorties auxquelles je ne suis pas inscrit/e
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="isPast" id="isPast" value="1"
                                            {% if filters.isPast %}checked{% endif %}>
                                        <label class="form-check-label" for="isPast">
                                            Sorties terminées
                                        </label>
                                    </div>
                                    <div class="text-end mt-2">
                                        <button type="submit" class="btn btn-outline-dark">Rechercher</button>
                                    </div>
                                </div>
                            </fieldset>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-sm table-striped table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Nom de la sortie</th>
                            <th scope="col">Date de la sortie</th>
                            <th scope="col">Clôture</th>
                            <th scope="col">Inscrits/Places</th>
                            <th scope="col">État</th>
                            <th scope="col">Inscrit</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for outing in outings %}
                        <tr>
                            <td data-label="Nom">{{ outing.name }}</td>
                            <td data-label="Date">{{ outing.startDateTime|date('d/m/Y H:i') }}</td>
                            <td data-label="Clôture">{{ outing.registrationDeadline|date('d/m/Y') }}</td>
                            <td data-label="Inscrits">{{ outing.registrations|length }}/{{ outing.maxRegistrations }}</td>
                            <td data-label="État">{{ outing.status }}</td>
                            <td data-label="Inscrit">
                                {% set isRegistered = false %}
                                {% if app.user %}
                                    {% set isRegistered = outing.registrations|filter(r => r.participant and r.participant.id == app.user.id)|length > 0 %}
                                {% endif %}
                                {{ isRegistered ? '✓' : '—' }}
                            </td>

                            <td data-label="Actions">
                                {% set isOrganizer = app.user and app.user.id == outing.organizer.id %}
                                {% set status = outing.status %}

                                <a href="{{ path('outing_detail', {id: outing.id}) }}" class="btn btn-sm btn-outline-dark">Afficher</a>

                                {% if app.user %}
                                    {% if not isOrganizer %}
                                        {% if status == 'ouverte' %}
                                            {% if isRegistered %}
                                                 <a href="{{ path('outing_unregister', {'id': outing.id}) }}" class="btn btn-sm btn-outline-light">Se désister</a>
                                            {% else %}
                                                 <a href="{{ path('outing_register', {'id': outing.id}) }}" class="btn btn-sm btn-outline-success">S'inscrire</a>
                                            {% endif %}
                                        {% endif %}
                                    {% endif %}

                                    {% if isOrganizer %}
                                        {% if status == 'creation' %}
                                            <a href="{{ path('manage_edit', {'id': outing.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                                            <a href="{{ path('manage_publish', {'id': outing.id}) }}" class="btn btn-sm btn-outline-success">Publier</a>
                                            <a href="{{ path('manage_edit', {'id': outing.id}) }}" class="btn btn-sm btn btn-outline-danger">Supprimer</a>
                                        {% endif %}
                                        {% if status == 'ouverte' %}
                                            <a href="{{ path('manage_cancel', {'id': outing.id}) }}" class="btn btn-sm btn-outline-danger">Annuler</a>
                                        {% endif %}
                                    {% endif %}
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center">Aucune sortie trouvée.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            {% set haveOrganizerRole = app.user.roles == ['ROLE_ORGANIZER'] %}

            {% if haveOrganizerRole %}
                <div class="mt-3">
                    <a href="{{ path('manage_create') }}" class="btn btn-outline-dark">Créer une sortie</a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
