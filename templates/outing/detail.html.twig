{% extends 'base.html.twig' %}

{% block title %}Afficher une sortie{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="h4 text-center mb-4">Afficher une sortie</h1>

        <div class="row">
            {# Colonne gauche : infos principales #}
            <div class="col-md-6">
                <div class="mb-2 row">
                    <label class="col-sm-5 col-form-label fw-semibold">Nom de la sortie</label>
                    <div class="col-sm-7">
                        <p class="form-control-plaintext">{{ outing.name }}</p>
                    </div>
                </div>
                <div class="mb-2 row">
                    <label class="col-sm-5 col-form-label fw-semibold">Date et heure de la sortie</label>
                    <div class="col-sm-7">
                        <p class="form-control-plaintext">{{ outing.startDateTime|date('d/m/Y H:i') }}</p>
                    </div>
                </div>
                <div class="mb-2 row">
                    <label class="col-sm-5 col-form-label fw-semibold">Date limite d'inscription</label>
                    <div class="col-sm-7">
                        <p class="form-control-plaintext">{{ outing.registrationDeadline|date('d/m/Y') }}</p>
                    </div>
                </div>
                <div class="mb-2 row">
                    <label class="col-sm-5 col-form-label fw-semibold">Nombre de places</label>
                    <div class="col-sm-7">
                        <p class="form-control-plaintext">{{ outing.maxRegistrations }}</p>
                    </div>
                </div>
                <div class="mb-2 row">
                    <label class="col-sm-5 col-form-label fw-semibold">Durée (en minutes)</label>
                    <div class="col-sm-7">
                        <p class="form-control-plaintext">{{ outing.duration }}</p>
                    </div>
                </div>
            </div>

            {# Colonne droite : localisation #}
            <div class="col-md-6">
                <div class="mb-2 row">
                    <label class="col-sm-5 col-form-label fw-semibold">Campus</label>
                    <div class="col-sm-7">
                        <p class="form-control-plaintext">{{ outing.campus.name }}</p>
                    </div>
                </div>
                <div class="mb-2 row">
                    <label class="col-sm-5 col-form-label fw-semibold">Ville</label>
                    <div class="col-sm-7">
                        <p class="form-control-plaintext">{{ outing.place.city.name }}</p>
                    </div>
                </div>
                <div class="mb-2 row">
                    <label class="col-sm-5 col-form-label fw-semibold">Lieu</label>
                    <div class="col-sm-7">
                        <p class="form-control-plaintext">{{ outing.place.name }}</p>
                    </div>
                </div>
                <div class="mb-2 row">
                    <label class="col-sm-5 col-form-label fw-semibold">Rue</label>
                    <div class="col-sm-7">
                        <p class="form-control-plaintext">{{ outing.place.street }}</p>
                    </div>
                </div>
                {# TODO: postalCode absent de l'entité Place pour l'instant #}
                <div class="mb-2 row">
                    <label class="col-sm-5 col-form-label fw-semibold">Latitude / Longitude</label>
                    <div class="col-sm-7">
                        <p class="form-control-plaintext">
                            {{ outing.place.latitude }} / {{ outing.place.longitude }}
                        </p>
                    </div>
                </div>
            </div>
        </div>

        {# Description sur toute la largeur #}
        <div class="mb-4 row mt-2">
            <label class="col-sm-2 col-form-label fw-semibold">Description et infos</label>
            <div class="col-sm-10">
                <p class="form-control-plaintext">{{ outing.eventInfo }}</p>
            </div>
        </div>

        {# Liste des participants #}
        <div class="mt-3">
            <h2 class="h6 fw-bold">Liste des participants inscrits</h2>
            <table class="table table-bordered table-sm" style="max-width: 400px;">
                <thead>
                <tr>
                    <th>Pseudo</th>
                    <th>Nom</th>
                </tr>
                </thead>
                <tbody>
                {% for registration in outing.registrations %}
                    <tr>
                        <td>
                            <a href="{{ path('app_profil_show', {'id': registration.participant.id}) }}">
                                {{ registration.participant.username }}
                            </a>
                        </td>
                        <td>{{ registration.participant.lastName }} {{ registration.participant.firstName }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="2" class="text-center">Aucun participant inscrit.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        {# Bouton Modifier visible uniquement pour l'organisateur #}
        {% if app.user == outing.organizer %}
            <div class="mt-3">
                <a href="{{ path('outing_edit', {'id': outing.id}) }}" class="btn btn-outline-dark">
                    Modifier
                </a>
            </div>
        {% endif %}

    </div>
{% endblock %}
