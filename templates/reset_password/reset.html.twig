{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Choisissez un nouveau mot de passe</h4>
                    </div>
                    <div class="card-body">
                        {{ form_start(resetForm) }}
                        {{ form_row(resetForm.plainPassword, {'row_attr': {'class': 'mb-3'}}) }}
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <a href="{{ path('app_login') }}" class="btn btn-secondary">Annuler</a>
                            <button class="btn btn-primary">Réinitialiser le mot de passe</button>
                        </div>
                        {{ form_end(resetForm) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
